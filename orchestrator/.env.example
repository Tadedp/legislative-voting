# Application
APP_NAME="Orchestrator Service"
APP_VERSION="0.1.0"
APP_ENV="development"
APP_DEBUG="true"
APP_HOST="0.0.0.0"
APP_PORT="8000"

# Database
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="orchestrator_db"
DB_USER="orchestrator_user"
DB_PASSWORD="orchestrator_password"
DB_POOL_MIN_SIZE="5"
DB_POOL_MAX_SIZE="20"
DB_POOL_TIMEOUT_SECONDS="30"
DB_POOL_RECYCLE_SECONDS="1800"

# Security
ARGON2_TIME_COST="2"
ARGON2_MEMORY_COST="65536"
ARGON2_PARALLELISM="2"
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8080"

# Logging
LOG_LEVEL="INFO"
SERVICE_NAME="orchestrator"